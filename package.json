{
  "name": "@ttqtt/liquid-glass-react",
  "version": "0.2.0",
  "description": "复刻 Apple Liquid Glass 质感的 React 组件库:边缘折射、动态高光、流体动效;Chromium 真折射,其余浏览器自动降级为毛玻璃。",
  "type": "module",
  "homepage": "https://tsdsj.github.io/liquid-glass-react/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tsdsj/liquid-glass-react.git"
  },
  "bugs": {
    "url": "https://github.com/Tsdsj/liquid-glass-react/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "site": "vite --config site/vite.config.ts",
    "site:build": "vite build --config site/vite.config.ts",
    "build": "vite build",
    "smoke:pack": "node scripts/smoke-pack.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm build && pnpm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "typecheck": "tsc --noEmit",
    "smoke:consumer": "node scripts/smoke-consumer.mjs"
  },
  "keywords": [
    "react",
    "components",
    "component-library",
    "ui",
    "glass",
    "liquid-glass",
    "glassmorphism",
    "backdrop-filter",
    "apple",
    "design-system"
  ],
  "author": "ttqtt",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.34.5",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.20"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/react-vite": "^9.1.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "axe-core": "^4.12.1",
    "jsdom": "^26.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^9.1.20",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.7"
  }
}
